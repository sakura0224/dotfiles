[user]
    name = sakura0224
    email = shiinayane@gmail.com

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = simple
    autoSetupRemote = true

[core]
    editor = nvim
    autocrlf = input
    pager = less -FRX
    excludesfile = ~/.gitignore_global

[color]
    ui = auto

[fetch]
    prune = true

[rerere]
    enabled = true

[alias]
    st = status
    co = checkout
    br = branch
    cm = commit
    amend = commit --amend --no-edit
    lg = log --oneline --graph --decorate --all
    last = log -1 HEAD

[merge]
    tool = nvimdiff

[diff]
    tool = nvimdiff

[credential]
    helper = osxkeychain
