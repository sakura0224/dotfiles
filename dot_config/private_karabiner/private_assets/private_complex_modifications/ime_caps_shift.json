{
  "title": "Caps / Shift tap for IME, hold for normal use",
  "rules": [
    {
      "description": "Caps Lock: tap = English, hold = Control",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": { "optional": ["any"] }
          },
          "to_if_alone": [
            {
              "select_input_source": {
                "language": "en"
              }
            }
          ],
          "to_if_held_down": [
            {
              "key_code": "left_control"
            }
          ]
        }
      ]
    },
    {
      "description": "Left Shift: tap = Chinese, hold = Shift",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_shift",
            "modifiers": { "optional": ["any"] }
          },
          "to_if_alone": [
            {
              "select_input_source": {
                "language": "zh"
              }
            }
          ],
          "to_if_held_down": [
            {
              "key_code": "left_shift"
            }
          ]
        }
      ]
    },
    {
      "description": "Right Shift: tap = Japanese, hold = Shift",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_shift",
            "modifiers": { "optional": ["any"] }
          },
          "to_if_alone": [
            {
              "select_input_source": {
                "language": "ja"
              }
            }
          ],
          "to_if_held_down": [
            {
              "key_code": "right_shift"
            }
          ]
        }
      ]
    }
  ]
}
